# Local development (with backend running on port 5000)
VITE_API_URL=http://localhost:5000/api

# Production (Vercel) — recommended: use /api (same-origin, uses vercel.json proxy)
# VITE_API_URL=/api

# Or call Render directly (requires CORS on backend):
# VITE_API_URL=https://techstore-kjo7.onrender.com/api
